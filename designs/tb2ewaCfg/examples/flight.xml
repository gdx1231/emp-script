				]]></Bottom></Set></AddHtml><AddScript><Set><Top/><Bottom><![CDATA[function refreshSerConns(rst) {
    if ("@EWA_PARENT_FRAME") {
        EWA.F.FOS["@EWA_PARENT_FRAME"].Reload();
    }
    // 删除窗口
    $('#opts_@SYS_FRAME_UNID').closest('.ewa-ui-dialog').remove()
}
(function() {
    const ewa = EWA.F.FOS['@SYS_FRAME_UNID'];
    ewa.ReloadAfter = function(httpReferer) {

    };
    ewa.ext_set = function() {
        let isok = true;
        $('#opts_@sys_frame_unid select').each(function() {
            if (!this.value) {
                $Tip('请选择' + $(this).closest('tr').find('.EWA_TD_L').text());
                $Mark(this);
                isok = false;
            }
        });
        if (!isok) {
            return;
        }
        changes();
        $('#flights_@sys_frame_unid #butOk1').trigger('click');
    }

    function changes() {
        let index = 0;
        $(`#flights_@sys_frame_unid .ewa-lf-frame:gt(0)`).remove();
        const ewa1 = EWA.F.getSubEwas('#flights_@sys_frame_unid')[0];
        getObj('input#ENQ_JNY_ID:checked').each(function() {
            const tr = $(this).closest('tr');
            if (index > 0) {
                $('#flights_@sys_frame_unid #butAdd').trigger('click');
            }
            let target = $(`#flights_@sys_frame_unid .ewa-lf-frame:eq(${index})`);

            const depatureCity = target.find('#A_D_CITY_ID');
            depatureCity.val(tr[0].dataset.fAdd);
            ewa1._GetDropListValue1(depatureCity.prev()[0], depatureCity[0]);

            const arrivalCity = target.find('#A_A_CITY_ID');
            arrivalCity.val(tr[0].dataset.cityId);
            ewa1._GetDropListValue1(arrivalCity.prev()[0], arrivalCity[0]);

            target.find('#A_BEGIN').val(tr[0].dataset.enqJnyDate.split(' ')[0])
            target.find('#A_END').val(tr[0].dataset.enqJnyDate.split(' ')[0])
            index++;
        });
    };

    function getObj(exp) {
        return exp ? $('#EWA_LF_@sys_frame_unid').find(exp) : $('#EWA_LF_@sys_frame_unid');
    }

    function init() {
        ewa.ReloadAfter();
        // tag3 = 113 团体
        // tag4 = 115 经济舱
        // tag6 = 2872 简单模式
        const u = "@ewa.cp/ewa?xmlName=/business/crm/sup_ser.xml&ITEMNAME=2025_SER_SET_SIG_SUP.F.Flight" +
            "&IATA=--&sup_id=3&SER_PRICE=0&coin_id=1&ewa_mtype=N&ser_id=1&TAG6=2872" +
            "&TAG3=113&TAG4=115&callback=refreshSerConns";
        $Install(u, 'flights_@sys_frame_unid', function() {
            const tag3 = $('#flights_@sys_frame_unid .ewa-row-TAG3').clone();
            const tag4 = $('#flights_@sys_frame_unid .ewa-row-TAG4').clone();
            console.log(tag3, tag4)
            $('#opts_@sys_frame_unid').append(tag3).append(tag4);
            $('#opts_@sys_frame_unid').find('select').on('change', function() {
                $(`#flights_@sys_frame_unid #${this.id}`).val(this.value);
            });
        });
        //getObj('input#ENQ_JNY_ID').on('change', changes);
    }
    init();
})();]]></Bottom></Set></AddScript><AddCss><Set><AddCss><![CDATA[#opts_@sys_frame_unid tr,
