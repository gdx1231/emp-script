ation="" Type="CheckError"><CallSet><Set CallIsChk="" CallName="CheckError SQL" CallType="SqlSet" Test=""/></CallSet></Set></ActionSet><SqlSet><Set Name="OnPageLoad SQL" SqlType="query"><Sql><![CDATA[SELECT
    A.*,
    c.city_cou_name AS deprture_city,
    d.city_cou_name AS arrival_city
FROM
    ENQ_JNY a
    INNER JOIN v_city c ON a.F_ADD = c.city_id
    INNER JOIN v_city d ON a.CITY_ID = d.city_id
WHERE
    A.ENQ_ID = @ENQ_ID
    and TRAFFIC ='AIR' -- 过滤需要机票
ORDER BY
    A.ENQ_JNY_DAY]]></Sql><CSSet/></Set><Set Name="OnFrameDelete SQL" SqlType="update"><Sql><![CDATA[UPDATE ENQ_JNY_SER_SUB_FLIGHT SET A_STATUS='DEL' , A_MDATE = @sys_date WHERE EA_ID = @EA_ID
	AND SUP_ID = @G_SUP_ID]]></Sql><CSSet/></Set><Set Name="OnFrameRestore SQL" SqlType="update"><Sql><![CDATA[UPDATE ENQ_JNY_SER_SUB_FLIGHT SET A_STATUS='USED' , A_MDATE = @sys_date WHERE EA_ID = @EA_ID
	AND SUP_ID = @G_SUP_ID]]></Sql><CSSet/></Set><Set Name="SAct0 SQL" SqlType="query"><Sql><![CDATA[-- enter your sql]]></Sql><CSSet/></Set><Set Name="SAct1 SQL" SqlType="query"><Sql><![CDATA[-- enter your sql]]></Sql><CSSet/></Set><Set Name="SAct2 SQL" SqlType="query"><Sql><![CDATA[-- enter your sql]]></Sql><CSSet/></Set><Set Name="UAct0 SQL" SqlType="update"><Sql><![CDATA[delete FROM ENQ_JNY_SER_SUB_FLIGHT WHERE EA_ENQ_JNY_SER_SUB_ID = -1 
    and EA_TMP_ID = @JSESSIONID
    and A_ID in (
        select col from ewa_split (@aids, ',') a
    )
;
WITH
    paras AS (
        SELECT
            a.col AS ea_id,
            b.col AS EA_ENQ_JNY_ID,
            c.col AS a_id
        FROM
            ewa_split (@eaIds, ',') a
            INNER JOIN ewa_split (@eaEnqJnyIds, ',') b ON a.idx = b.idx
            INNER JOIN ewa_split (@aids, ',') c ON c.idx = a.idx
    )
INSERT INTO
    ENQ_JNY_SER_SUB_FLIGHT (
        EA_ENQ_JNY_SER_SUB_ID,
        A_ID,
        A_D_CITY_ID,
        A_A_CITY_ID,
        A_CODE,
        A_IATA,
        A_D_TIME,
        A_A_TIME,
        A_D_AIRPORT,
        A_A_AIRPORT,
        A_D_AIRPORT_ID,
        A_A_AIRPORT_ID,
        A_TRANSFOR,
        A_PLANE,
        A_TIME,
        A_EAT,
        A_REF,
        A_DISTANCE,
        A_DESCRIPTION,
        A_CDATE,
        A_STATUS,
        SUP_ID,
        ADM_ID,
        A_SER_CONN_ID,
        A_BEGIN,
        A_END,
        EA_ENQ_JNY_DATE,
        EA_ENQ_JNY_ID,
        EA_ENQ_ID,
        EA_GRP_ID,
        EA_TMP_ID
    )
SELECT
    -1,
    a.A_ID,
    a.A_D_CITY_ID,
    a.A_A_CITY_ID,
    a.A_CODE,
    a.A_IATA,
    a.A_D_TIME,
    a.A_A_TIME,
    a.A_D_AIRPORT,
    a.A_A_AIRPORT,
    a.A_D_AIRPORT_ID,
    a.A_A_AIRPORT_ID,
    a.A_TRANSFOR,
    a.A_PLANE,
    a.A_TIME,
    a.A_EAT,
    a.A_REF,
    a.A_DISTANCE,
    a.A_DESCRIPTION,
    @sys_date,
    'USED',
    @G_SUP_ID,
    @G_ADM_ID,
    a.A_SER_CONN_ID,
    a.A_BEGIN,
    a.A_END,
    c.ENQ_JNY_DATE,
    b.EA_ENQ_JNY_ID,
    @ENQ_ID,
    c.GRP_ID,
    @JSESSIONID
FROM
    SER_CONN_FLIGHT a
    INNER JOIN paras b ON a.a_id = b.a_id
        AND ea_id = -1
    INNER JOIN enq_jny c ON b.EA_ENQ_JNY_ID = c.enq_jny_id
        AND c.ENQ_ID = @ENQ_ID
WHERE
    a.A_STATUS = 'USED'
select 1 a]]></Sql><CSSet/></Set><Set Name="UAct1 SQL" SqlType="update"><Sql><![CDATA[-- enter your sql]]></Sql><CSSet/></Set><Set Name="UAct2 SQL" SqlType="update"><Sql><![CDATA[-- enter your sql]]></Sql><CSSet/></Set><Set Name="CheckError SQL" SqlType="query"><Sql><![CDATA[-- select 不能执行/javascript_func() as EWA_ERR_OUT FROM xxx where 1=2]]></Sql><CSSet/></Set></SqlSet><JSONSet/><ClassSet/><XmlSet/><XmlSetData/><ScriptSet/><UrlSet/><CSSet/><CallSet><Set CallIsChk="" CallName="OnPageLoad SQL" CallType="SqlSet" Test=""/></CallSet></Action><XItems><XItem Name="ENQ_JNY_ID"><Tag><Set IsLFEdit="" SpanShowAs="" Tag="checkboxgrid"/></Tag><Name><Set Name="ENQ_JNY_ID"/></Name><GroupIndex/><InitValue/><DescriptionSet><Set Info="选择" Lang="zhcn" Memo=""/></DescriptionSet><XStyle/><Style/><ParentStyle/><AttributeSet/><EventSet/><IsHtml/><OrderSearch><Set GroupTestLength="" IsGroup="" IsGroupDefault="" IsOrder="0" IsSearchQuick="" OrderExp="" SearchExp="" SearchMulti="" SearchSql="" SearchType=""/></OrderSearch><MaxMinLength/><MaxMinValue/><IsMustInput/><Switch/><DataItem><Set DataField="ENQ_JNY_ID" DataType="" DisableOnModify="" Format="" FrameOneCell="" Icon="" IconLoction="" IsEncrypt="" NumberScale="" SumBottom="" TransTarget="" Translation="" TriggerValid="" Trim="" Valid=""/></DataItem><DispEnc/><DataRef/><List/><UserSet/><CallAction/><OpenFrame/><Frame/><UserControl/><DefineFrame/><PopFrame/><signature/><Upload/><VaildEx/><MGAddField/><AnchorParas/><LinkButtonParas/><DopListShow/><ReportCfg/><CombineFrame/><AddrMapRels/><QRCode/><ImageDefault/></XItem><XItem Name="ENQ_JNY_DATE"><Tag><Set IsLFEdit="0" SpanShowAs="" Tag="span"/></Tag><Name><Set Name="ENQ_JNY_DATE"/></Name><GroupIndex><Set GroupIndex=""/></GroupIndex><InitValue><Set InitValue=""/></InitValue><DescriptionSet><Set Info="日期" Lang="zhcn" Memo=""/><Set Info="Select the schedule" Lang="enus" Memo=""/></DescriptionSet><XStyle><Set XStyleAlign="" XStyleBold="" XStyleColor="" XStyleCursor="" XStyleFixed="" XStyleNoWr