<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  EWA Define Settings - EWA 定义配置
  用于配置 Frame 和 ListFrame 模式的字段显示/隐藏规则和页面配置
-->
<EwaDefineSettings>
  <!-- Frame 模式配置 -->
  <Frame>
    <!-- 字段隐藏规则 -->
    <FieldHideRules>
      <!-- 按字段后缀隐藏 -->
      <HideBySuffix>
        <Suffix Name="_CDATE" Description="创建时间字段"/>
        <Suffix Name="_MDATE" Description="修改时间字段"/>
        <Suffix Name="_STATUS" Description="状态字段"/>
        <Suffix Name="_STATE" Description="状态字段"/>
      </HideBySuffix>
      
      <!-- 按字段类型隐藏 -->
      <HideByType>
        <Type Name="IDENTITY" Description="自增字段"/>
      </HideByType>
      
      <!-- 按字段名精确匹配隐藏 -->
      <HideByName>
        <!-- 可添加特定字段名 -->
      </HideByName>
    </FieldHideRules>
    
    <!-- 页面配置 -->
    <PageSettings>
      <Size Width="700" HiddenCaption="1" FrameCols="C2" HAlign="center" VAlign="top"/>
    </PageSettings>
  </Frame>
  
  <!-- ListFrame 模式配置 -->
  <ListFrame>
    <!-- 页面配置 -->
    <PageSettings>
      <Size Width="100%" HiddenCaption="" FrameCols="" HAlign="center" VAlign="top"/>
      <PageSize IsSplitPage="1" PageSize="10" Recycle="1"/>
      <ListUI luButtons="1" luSearch="1" luSelect="S"/>
    </PageSettings>
    
    <!-- OrderSearch 配置规则 -->
    <OrderSearchRules>
      <!-- 数字类型：IsOrder=1, SearchType="" -->
      <Rule Type="INT,DECIMAL,NUM,DOUBLE,FLOAT,MONEY" IsOrder="1" SearchType=""/>
      
      <!-- 日期类型：IsOrder=1, SearchType="" -->
      <Rule Type="DATE,TIME,TIMESTAMP" IsOrder="1" SearchType=""/>
      
      <!-- 文字类型<=100：IsOrder=1, SearchType="text" -->
      <Rule Type="CHAR,TEXT" MaxLength="100" IsOrder="1" SearchType="text"/>
      
      <!-- 文字类型>100：IsOrder=0, SearchType="text" -->
      <Rule Type="CHAR,TEXT" MaxLength="9999" IsOrder="0" SearchType="text"/>
    </OrderSearchRules>
  </ListFrame>
  
  <!-- 字段格式配置（通用） -->
  <FieldFormats>
    <!-- 日期时间类型 -->
    <Format Type="DATETIME,TIMESTAMP" Value="DateShortTime"/>
    <Format Type="DATE" Value="Date"/>
    <Format Type="TIME" Value="Time"/>

    <!-- 货币类型 -->
    <Format Type="MONEY,DECIMAL,NUMERIC" Value="LeastMoney"/>

    <!-- 整数类型 -->
    <Format Type="INT,BIGINT,SMALLINT,TINYINT" Value="Int"/>

    <!-- 数字精度配置 -->
    <NumberScale Type="DECIMAL,NUMERIC,MONEY" Value="2"/>
  </FieldFormats>
  
  <!-- 字段 Tag 类型配置（通用） -->
  <FieldTags>
    <!-- 日期时间类型 -->
    <Tag Type="DATETIME,TIMESTAMP" Value="datetime"/>
    <Tag Type="DATE" Value="date"/>
    <Tag Type="TIME" Value="time"/>
    
    <!-- 长文本类型 -->
    <Tag Type="TEXT,MEMO,LONGVARCHAR,LONGNVARCHAR" Value="textarea"/>
    
    <!-- 数字类型：使用 text，通过 DataType 和 Valid 控制 -->
    <!-- <Tag Type="INT,DECIMAL,NUM" Value="text"/> -->
    
    <!-- 默认类型 -->
    <Tag Type="DEFAULT" Value="text"/>
  </FieldTags>
</EwaDefineSettings>
