        <AddScript>
            <Set>
                <Top><![CDATA[var trans;

function aa(fromObj) {
    var obj1 = fromObj.parentNode.parentNode.cells[2].getElementsByTagName('span')[0];
    if (obj1 == null) {
        return;
    }
    if (obj1.innerHTML != '') {
        return;
    }
    if (trans == null) {
        trans = new EWA_UT_TRANS();
    }
    trans.TransToEn(fromObj.innerHTML, obj1);
}

function bb() {
    if (idx <= ipts.length - 1) {
        aa(ipts[idx]);
        idx++;
        setTimeout(bb, 123);
        return;
    }
    setTimeout(cc, 1231);
}

function cc() {
    var ids = [];
    var vals = [];
    for (var i = 0; i < ipts.length; i++) {
        var tr = ipts[i].parentNode.parentNode;
        var span = tr.cells[2].getElementsByTagName('span')[0];
        if (span.getAttribute('ewa_trans_end') == 'ok') {
            ids.push(tr.getAttribute('EWA_KEY'));
            vals.push(GetInnerText(span));
        }
    }
    if (ids.length == 0) {
        return;
    }
    var ajax = new EWA_AjaxClass();
    ajax.AddParameter('ids', ids.join('`'));
    ajax.AddParameter('vals', vals.join('`'));
    ajax.AddParameter('EWA_ACTION', 'EXTENDACTION2');
    ajax.AddParameter('EWA_AJAX', 'JSON');
    ajax.PostNew(window.location.href, function() {
        if (ajax.IsRunEnd()) {
            alert('ok');
        }
    });
}
var ipts;
var idx;

function tall() {
    ipts = $F(document.body, 'span', 'id', 'MNU_TEXT');
    idx = 0;
    bb();
}]]></Top>
                <Bottom><![CDATA[(function() {
    let ewa = EWA.F.FOS['@SYS_FRAME_UNID'];

    ewa.ReloadAfter = function(httpReferer) {
        ewa.Merge('MNU_TEXT_EN', 'MNU_TEXT', '');
        ewa.Merge('P_MNU_TEXT_EN', 'P_MNU_TEXT','<br>');
    };

    ewa.submit_chooese = function() {
        let ids = ewa.SelectChecked();
        if (ids == '') {
            $Tip('请先选择');
            return;
        }
        if ("@MG_TAG") {
            var u1 = new EWA_UrlClass(EWA.F.FOS["@SYS_FRAME_UNID"].Url);
            u1.AddParameter("ewa_action", "ExtendAction0");
            u1.AddParameter("ewa_ajax", "json");
            var u = u1.GetUrl();
            let data = {
                ids: ids,
                mg_tag: "@MG_TAG"
            }
            $JP(u, data, function(rst) {
                $Tip('提交完毕')
            });
        } else {
             $Tip('未知的操作方法');
            return;
        }
        
    };

    function getObj(exp) {
        return exp ? $('#EWA_LF_@sys_frame_unid').find(exp) : $('#EWA_LF_@sys_frame_unid');
    }

    // 执行刷新后事件
    function init() {
        ewa.ReloadAfter();
    }
    init();
})();]]></Bottom>
