        <SqlSet>
            <Set Name="OnPageLoad SQL" SqlType="query">
                <Sql><![CDATA[WITH MenuTree AS (
		-- 定位点：起始节点
		SELECT mnu_id, mnu_pid, 0 AS level
		FROM adm_menu
		WHERE mnu_id = @mnu_pid
		UNION ALL
		-- 递归点：查找子节点
		SELECT m.mnu_id, m.mnu_pid, mt.level + 1
		FROM adm_menu m
		INNER JOIN MenuTree mt ON m.mnu_pid = mt.mnu_id
	)
SELECT A.*, B.*
FROM ADM_MENU A
    inner join MenuTree mt on a.mnu_id=mt.mnu_id
	LEFT JOIN (
		SELECT B.MNU_ID AS ID, B.MNU_TEXT AS P_MNU_TEXT, B.MNU_TEXT_EN AS P_MNU_TEXT_EN
		FROM ADM_MENU B
	) B
	ON A.MNU_PID = B.ID
WHERE a.mnu_id!=@MNU_PID
    AND
     (A.MNU_GRP = @MNU_GRP 	OR @MNU_GRP IS NULL)
ORDER BY  A.MNU_ORD]]></Sql>
                <CSSet />
            </Set>
            <Set Name="ExtendAction0 SQL" SqlType="query">
                <Sql><![CDATA[delete FROM ADM_MENU_GRP_IDS where MG_TAG = @MG_TAG;

insert INTO ADM_MENU_GRP_IDS(MG_TAG, MNU_ID)
SELECT @MG_TAG, MNU_ID FROM ADM_MENU A 
    INNER JOIN EWA_SPLIT(@IDS, ',') B ON A.MNU_ID = B.COL
;

UPDATE ADM_MENU_GRP SET MNU_IDS = @IDS WHERE MG_TAG = @MG_TAG;]]></Sql>
                <CSSet />
            </Set>
            <Set Name="ExtendAction1 SQL" SqlType="query">
                <Sql><![CDATA[-- enter your sql]]></Sql>
                <CSSet />
            </Set>
            <Set Name="ExtendAction2 SQL" SqlType="update">
                <Sql><![CDATA[UPDATE ADM_MENU SET MNU_TEXT_EN=V FROM (
  	SELECT A.COL ID, B.COL V FROM F_SPLITA(@IDS,'`') A
  		INNER JOIN F_SPLITA(@VALS,'`') B ON A.IDX=B.IDX
  ) A
WHERE A.ID = MNU_ID
]]></Sql>
                <CSSet />
            </Set>
