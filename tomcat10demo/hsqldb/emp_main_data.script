INSERT INTO "CITY" VALUES(282,'\u6d1b\u6749\u77f6','Los Angeles',264,' LAX','2005',2,'\u5bf9\u4e8e\u90a3\u4e9b\u6e34\u671b\u611f\u53d7\u6d6e\u534e\u57ce\u9b45\u529b\u7684\u6e38\u5ba2\uff0c\u597d\u83b1\u575e\u6b63\u5411\u4ed6\u4eec\u53ec\u5524\u3002 \u60a8\u53ef\u4ee5\u5728\u7247\u573a\u6e38\u89c8\uff0c\u4e5f\u53ef\u4ee5\u5c06\u624b\u653e\u5165 TCL \u4e2d\u56fd\u5267\u9662\u7684\u8457\u540d\u624b\u5370\u5185\uff0c\u6216\u5728\u6d1b\u6749\u77f6\u7684\u72c2\u70ed\u591c\u603b\u4f1a\u4e2d\u4e00\u7779\u660e\u661f\u98ce\u91c7\u3002 \u60a8\u53ef\u80fd\u5728\u683c\u7f57\u592b\u8d2d\u7269\u4e2d\u5fc3 (The Grove) \u649e\u89c1\u4f60\u6700\u559c\u7231\u7684\u660e\u661f\uff0c\u53c8\u6216\u662f\u5728\u76d6\u8482\u4e2d\u5fc3 (The Getty Center) \u6b23\u8d4f\u6807\u5fd7\u6027\u7684\u827a\u672f\u54c1\u65f6\uff0c\u5c06\u90a3\u4e9b\u517b\u773c\u7684\u540d\u4eba\u5168\u7136\u5fd8\u5374\u3002 \u5728\u683c\u91cc\u83f2\u65af\u5929\u6587\u53f0 (Griffith Observatory)\uff0c\u60a8\u53ef\u4ee5\u900f\u8fc7\u671b\u8fdc\u955c\u8fdb\u884c\u4e00\u6b21\u522b\u5f00\u751f\u9762\u7684\u661f\u8c61\u89c2\u6d4b\u3002','USA-CITY','-','8:0','2014-03-01','2014-10-31',-118.24368490000000000000000000,34.05223420000000000000000000,NULL,20055,71,NULL,'',NULL,'2005',4,'USED')
